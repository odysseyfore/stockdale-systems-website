---
// Import components
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Services from '../components/Services.astro';
import Philosophy from '../components/Philosophy.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
    <Header />
    <main>
        <Hero />
        <Services />
        <Philosophy />
        <About />
        <Contact />
    </main>
    <Footer />

    <script>
        // Simple script to handle form submission without a backend.
        // This prevents the page from reloading and shows a message.
        // In a real application, you would connect this to a form handling service
        // like Netlify Forms, Formspree, or a custom backend.
        const form = document.getElementById('contactForm') as HTMLFormElement;
        const formMessage = document.getElementById('form-message');

        if (form && formMessage) {
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                formMessage.textContent = 'Thank you for your message! I will be in touch shortly.';
                formMessage.className = 'mt-4 text-center text-green-400';
                
                form.reset();

                setTimeout(() => {
                    formMessage.textContent = '';
                    formMessage.className = 'mt-4 text-center';
                }, 5000);
            });
        }
    </script>
</Layout>
