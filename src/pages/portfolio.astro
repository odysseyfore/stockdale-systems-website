---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Portfolio | Stockdale Systems" description="A selection of successful projects demonstrating Stockdale Systems' expertise in building robust and efficient custom software solutions.">
    <Header />
    <main class="pt-24">
        <section class="py-20 bg-white">
            <div class="container mx-auto px-6">
                <div class="text-center mb-16">
                    <h1 class="text-4xl md:text-5xl font-bold text-gray-900">Project Portfolio</h1>
                    <p class="mt-4 text-lg text-gray-600 max-w-3xl mx-auto">A selection of recent engagements showing how I help manufacturers tighten their ERP systems, processes, and data. Client names are withheld to respect confidentiality.</p>
                </div>

                <div class="space-y-16">
                    <!-- Project 1 -->
                    <div class="grid md:grid-cols-2 gap-12 items-center">
                        <div>
                            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015&auto=format&fit=crop" alt="Precision manufacturing operations and enterprise systems" class="rounded-xl shadow-lg w-full object-cover aspect-video">
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-gray-900 mb-3">Epicor Kinetic Shop Floor Discipline Review</h2>
                            <p class="text-gray-700 mb-4">
                                Conducted an on-site shop floor walk-through and transactional discipline analysis for a precision manufacturer running Epicor Kinetic, then translated the findings into an executable closeout program.
                            </p>
                            <ul class="list-disc list-inside text-gray-600 space-y-2">
                                <li>Delivered findings and recommendations with a stable, traceable ID system.</li>
                                <li>Produced a color-coded executive summary matrix prioritizing the highest-impact issues.</li>
                                <li>Identified and prioritized 13 critical (P1) items into a structured closeout program.</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Project 2 -->
                    <div class="grid md:grid-cols-2 gap-12 items-center">
                        <div class="md:order-2">
                            <img src="https://images.unsplash.com/photo-1611532736597-de2d4265fba3?q=80&w=2187&auto=format&fit=crop" alt="Stakeholder discovery session for an enterprise systems assessment" class="rounded-xl shadow-lg w-full object-cover aspect-video">
                        </div>
                        <div class="md:order-1">
                            <h2 class="text-2xl font-bold text-gray-900 mb-3">Manufacturing ERP Discovery &amp; Remediation</h2>
                            <p class="text-gray-700 mb-4">
                                Ran a structured discovery engagement for a multi-brand manufacturer, mapping current-state systems, processes, and team culture across the ERP, customer portal, and product information tooling.
                            </p>
                            <ul class="list-disc list-inside text-gray-600 space-y-2">
                                <li>Scoped and executed a fixed-scope Discovery Statement of Work with clear deliverables.</li>
                                <li>Led stakeholder interviews across product, engineering, and executive leadership.</li>
                                <li>Translated findings into a prioritized current-state assessment and remediation roadmap.</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Project 3 -->
                    <div class="grid md:grid-cols-2 gap-12 items-center">
                        <div>
                            <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=2070&auto=format&fit=crop" alt="Industrial print and graphics production workflow" class="rounded-xl shadow-lg w-full object-cover aspect-video">
                        </div>
                        <div>
                            <h2 class="text-2xl font-bold text-gray-900 mb-3">Web-to-Print Automation &amp; Integration</h2>
                            <p class="text-gray-700 mb-4">
                                Built automation and integration tooling for an industrial print and graphics manufacturer, removing manual steps from a high-volume web-to-print production workflow.
                            </p>
                            <ul class="list-disc list-inside text-gray-600 space-y-2">
                                <li>Developed a PDF automation pipeline for compression, organization, and compositing.</li>
                                <li>Integrated and debugged the connection between internal systems and a web-to-print portal.</li>
                                <li>Delivered a production tracking application spanning multiple facilities and venues.</li>
                            </ul>
                        </div>
                    </div>

                </div>
            </div>
        </section>
    </main>
    <Footer />
</Layout>